{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog",
    "description": "Blog posts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "heading": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "heading",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "breadcrumbTitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "excerpt": {
      "type": "text",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "subtitle": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "thumbnailAlt": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "featuredImageAlt": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "publishDate": {
      "type": "date",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["generic", "horoscope"]
    },
    "visibilityStatus": {
      "type": "enumeration",
      "enum": ["draft", "live"]
    },
    "zodiacSign": {
      "type": "enumeration",
      "enum": [
        "aries",
        "taurus",
        "gemini",
        "cancer",
        "leo",
        "virgo",
        "libra",
        "scorpio",
        "sagittarius",
        "capricorn",
        "aquarius",
        "pisces"
      ]
    },
    "noindex": {
      "type": "boolean"
    },
    "trending": {
      "type": "boolean"
    },
    "priority": {
      "type": "integer"
    },
    "seo_schema": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "blogs",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "blogs",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "sub_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sub-category.sub-category",
      "inversedBy": "blogs",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "mappedBy": "blogs",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "relatedArticles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog.blog",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "content.heading-blocks",
        "content.paragraphs",
        "content.image-blocks",
        "content.video-embeds",
        "content.quote-blocks",
        "content.call-to-actions",
        "content.table-of-contents",
        "content.tables",
        "body.bodies",
        "shared.rich-text",
        "shared.quote",
        "shared.media",
        "shared.slider"
      ],
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
