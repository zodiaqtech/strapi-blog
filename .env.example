# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# Database (PostgreSQL)
DATABASE_CLIENT=postgres
DATABASE_HOST=your-postgres-host.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=strapi_db
DATABASE_USERNAME=strapi_admin
DATABASE_PASSWORD=your-secure-password
DATABASE_SSL=true

# Azure Blob Storage (for media uploads)
STORAGE_ACCOUNT=yourstorageaccount
STORAGE_ACCOUNT_KEY=your-storage-account-key
STORAGE_CONTAINER_NAME=strapi-uploads
STORAGE_URL=https://yourstorageaccount.blob.core.windows.net

# App URL (your Container App URL)
PUBLIC_URL=https://your-strapi-app.azurecontainerapps.io
